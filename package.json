{
  "name": "lumenstack-ai",
  "version": "1.0.0",
  "description": "AI architecture intelligence workspace for repository analysis, diagrams, compare reviews, codebase chat, and recruiter-ready briefs.",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "node --env-file-if-exists=.env --watch server.js",
    "smoke": "node --env-file-if-exists=.env scripts/smoke-test.js",
    "openai:check": "node --env-file-if-exists=.env scripts/openai-check.js",
    "site:audit": "node --env-file-if-exists=.env scripts/site-audit.js",
    "security:audit": "node --env-file-if-exists=.env scripts/security-audit.js"
  },
  "keywords": [
    "architecture",
    "repository-analysis",
    "ai",
    "code-review",
    "mermaid",
    "openai",
    "express",
    "portfolio",
    "recruiter-ready"
  ],
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "express": "^4.21.2",
    "mermaid": "^11.12.0",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "tsparticles-slim": "^2.12.0"
  },
  "homepage": "https://lumenstack-ai.onrender.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agarwalujala3-lang/LumenStack-AI.git"
  },
  "bugs": {
    "url": "https://github.com/agarwalujala3-lang/LumenStack-AI/issues"
  },
  "engines": {
    "node": ">=20"
  }
